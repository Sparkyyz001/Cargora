# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
# In production: set to your actual domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── 2GIS Maps ────────────────────────────────────────────────────────────────
# Get from: https://dev.2gis.com → Dashboard → Create API key
NEXT_PUBLIC_2GIS_API_KEY=your_2gis_api_key_here

# ─── Groq AI ──────────────────────────────────────────────────────────────────
# Get from: https://console.groq.com → API Keys
# Used server-side only (not exposed to client)
GROQ_API_KEY=your_groq_api_key_here

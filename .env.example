# =============================================================
# CARGORA — Environment Variables Template
# =============================================================
# Все реальные ключи хранятся локально в .env.local
# и НЕ попадают в репозиторий (.gitignore → .env*.local)
#
# Для запуска проекта: скопируй этот файл в .env.local
# и вставь свои ключи из соответствующих сервисов.
# =============================================================

# Supabase — https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site URL (localhost в dev, домен в prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 2GIS Maps API — https://dev.2gis.com
NEXT_PUBLIC_2GIS_API_KEY=

# Groq AI — https://console.groq.com (только server-side, клиенту не видно)
GROQ_API_KEY=
